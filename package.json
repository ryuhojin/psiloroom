{
  "name": "psiloroom",
  "private": true,
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "db:up": "docker compose up -d postgres redis",
    "db:push": "prisma db push",
    "db:seed": "pnpm prisma:seed",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm test:api && pnpm test:web",
    "test:api": "pnpm --filter admin-api test && pnpm --filter user-api test",
    "test:web": "pnpm --filter admin-web test && pnpm --filter user-web test",
    "test:e2e": "playwright test",
    "test:ci": "pnpm test:api && pnpm test:web && pnpm test:e2e",
    "prisma:generate": "prisma generate",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
